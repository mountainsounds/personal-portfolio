# Copy this file to .env.local and fill in real values.
# Never commit .env.local — it's gitignored.

# --- Resend (contact form email) ---
# Shares the Resend account/domain used by other mountainsounds apps;
# mtnsounds.com is the verified sending domain.
#   RESEND_API_KEY       → Resend dashboard → API Keys (re_...)
#   RESEND_FROM_EMAIL    → "Zack Sawyer <notifications@mtnsounds.com>"
#   CONTACT_NOTIFY_EMAIL → where contact form messages land (optional;
#                          defaults to mountainsounds15@gmail.com). Use
#                          delivered@resend.dev while testing.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
CONTACT_NOTIFY_EMAIL=
